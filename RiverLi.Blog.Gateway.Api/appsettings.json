{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity_route": {
        "ClusterId": "identity_service",
        "CorsPolicy": "GatewayCorsPolicy", // 👈 显式绑定你在 Program.cs 中配置的跨域策略
        "Match": {
          "Path": "/api/identity/{**remainder}"
        }
      },
      "blog_route": {
        "ClusterId": "blog_service",
        "CorsPolicy": "GatewayCorsPolicy", // 👈 显式绑定跨域策略
        "Match": {
          "Path": "/api/blog/{**remainder}"
        }
      },
      "file_route": {
        "ClusterId": "file_service",
        "CorsPolicy": "GatewayCorsPolicy", // 👈 显式绑定跨域策略
        "Match": {
          "Path": "/api/file/{**remainder}"
        }
      },
      "quartz-route": {
        "ClusterId": "quartz-cluster",
        "CorsPolicy": "GatewayCorsPolicy", // 👈 显式绑定跨域策略
        "Match": {
          "Path": "/api/quartz/{**catch-all}"
        }
      },
      "consul_route": {
        "ClusterId": "consul_service",
        "CorsPolicy": "GatewayCorsPolicy", // 👈 显式绑定跨域策略
        "Match": {
          "Path": "/api/consul/{**remainder}"
        }
      }
    },
    "Clusters": {
      "identity_service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "blog_service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "quartz-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5135"
          }
        }
      },
      "consul_service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5050"
          }
        }
      },
      "file_service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      }
    }
  },
  "Jwt": {
    "SecretKey": "RiverLi_Blog_Very_Secret_Key_Must_Be_Long_Enough_32_Chars",
    "Issuer": "RiverBlog.Identity",
    "Audience": "RiverBlog.Clients",
    "ExpiryMinutes": 60
  }
}
//逻辑解释：
//访问 gateway:port/api/auth/login -> 转发到 IdentityService/login
//访问 gateway:port/api/v1/blog/articles -> 转发到 BlogService/articles
//现在你的系统结构如下：服务名称端口访问路径示例 
//  /Identity Service5001/login, 
//  /registerBlog Service5002/articles, 
//  /commentsYARP Gateway5000/api/auth/login, 
//  /api/v1/blog/articles
