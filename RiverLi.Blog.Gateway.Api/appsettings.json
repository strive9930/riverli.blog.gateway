{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity_route": { 
        "ClusterId": "identity_service",
        "Match": {
          "Path": "/api/identity/{**remainder}"
        }
      },
      "blog_route": {
        "ClusterId": "blog_service",
        "Match": {
          "Path": "/api/v1/blog/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/v1/blog" },
          { "X-Forwarded": "Set" }
        ]
      },
      "file_route": {
        "ClusterId": "file_service",
        "Match": { "Path": "/api/v1/files/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api/v1/files" } ]
      }
    },
    "Clusters": {
      "identity_service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "blog_service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      }
    }
  },
  "Jwt": {
    "SecretKey": "RiverLi_Blog_Very_Secret_Key_Must_Be_Long_Enough_32_Chars",
    "Issuer": "RiverBlog.Identity",
    "Audience": "RiverBlog.Clients",
    "ExpiryMinutes": 60
  }
}
//逻辑解释：
//访问 gateway:port/api/auth/login -> 转发到 IdentityService/login
//访问 gateway:port/api/v1/blog/articles -> 转发到 BlogService/articles
//现在你的系统结构如下：服务名称端口访问路径示例 
//  /Identity Service5001/login, 
//  /registerBlog Service5002/articles, 
//  /commentsYARP Gateway5000/api/auth/login, 
//  /api/v1/blog/articles
